{
  "id": null,
  "uid": "zyphron-sre",
  "title": "Zyphron — SRE Overview",
  "description": "Platform health: active deployments, error rate, request volume, Redis memory",
  "tags": ["zyphron"],
  "timezone": "browser",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Active Deployments",
      "description": "Deployments currently in LIVE status",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red",    "value": 25 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_active_deployments",
          "legendFormat": "Active",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Projects",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_projects_total",
          "legendFormat": "Projects",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Total Users",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_users_total",
          "legendFormat": "Users",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Pending Deployments",
      "description": "Deployments currently QUEUED, BUILDING, or DEPLOYING",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "datasource": "Prometheus",
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red",    "value": 10 }
            ]
          },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_pending_deployments",
          "legendFormat": "Pending",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Deployments by Status",
      "description": "Count of deployments in each status over time",
      "gridPos": { "h": 8, "w": 16, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "table", "placement": "right", "showLegend": true },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10,
            "gradientMode": "none",
            "lineWidth": 2,
            "pointSize": 5,
            "showPoints": "never",
            "spanNulls": false
          },
          "mappings": [],
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "LIVE"     }, "properties": [{ "id": "color", "value": { "fixedColor": "green",  "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "FAILED"   }, "properties": [{ "id": "color", "value": { "fixedColor": "red",    "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "BUILDING" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "QUEUED"   }, "properties": [{ "id": "color", "value": { "fixedColor": "blue",   "mode": "fixed" } }] }
        ]
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_deployments_by_status",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Redis Memory Usage",
      "description": "Memory consumed by Redis (bytes)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 4 },
      "datasource": "Prometheus",
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 15,
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_redis_memory_bytes",
          "legendFormat": "Redis",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Total Deployments (Cumulative)",
      "description": "Cumulative deployment count over time",
      "gridPos": { "h": 7, "w": 24, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "options": {
        "legend": { "calcs": ["last"], "displayMode": "list", "placement": "bottom", "showLegend": true },
        "tooltip": { "mode": "single", "sort": "none" }
      },
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20,
            "gradientMode": "hue",
            "lineWidth": 2,
            "showPoints": "never",
            "spanNulls": false
          },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] },
          "mappings": []
        },
        "overrides": []
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "zyphron_deployments_total",
          "legendFormat": "Total Deployments",
          "refId": "A"
        }
      ]
    }
  ]
}
