# ===========================================
# ZYPHRON — Environment Template
# ─ Local dev:  cp .env.example .env
# ─ Production: values are set via .env.prod
#               (generated by scripts/setup-server.sh)
# ===========================================

# ─── App ────────────────────────────────────────────────────
NODE_ENV=development          # production on server
PORT=3003
HOST=0.0.0.0
LOG_LEVEL=info                # debug locally, info/warn on server

# ─── Database ───────────────────────────────────────────────
# Local dev — docker-compose.dev.yml maps postgres to :5433
DATABASE_URL=postgresql://zyphron:zyphron_secret@localhost:5433/zyphron?schema=public
# Server — docker-compose.prod.yml sets this automatically via service name

# ─── Redis ──────────────────────────────────────────────────
# Local dev — docker-compose.dev.yml maps redis to :6380
REDIS_URL=redis://localhost:6380
# Server — docker-compose.prod.yml sets this automatically via service name

# ─── Kafka (disabled — saves ~1 GB RAM) ─────────────────────
KAFKA_ENABLED=false
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=zyphron

# ─── Auth ───────────────────────────────────────────────────
# REQUIRED — generate with: openssl rand -hex 32
JWT_SECRET=
JWT_EXPIRES_IN=7d

# REQUIRED — generate with: openssl rand -hex 16
ENCRYPTION_KEY=

# First signup with this email becomes admin
BOOTSTRAP_ADMIN_EMAILS=you@example.com

# Dev only — NEVER true on server
ALLOW_DEV_TOKEN_BYPASS=false

# ─── GitHub OAuth  (optional — "Login with GitHub") ─────────
# Create at: github.com/settings/applications/new
# Homepage URL:  https://zyphron.space
# Callback URL:  https://api.zyphron.space/api/v1/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3003/api/v1/auth/github/callback

# ─── Google OAuth  (optional — "Login with Google") ─────────
# Create at: console.cloud.google.com → Credentials → OAuth 2.0
# Callback URL:  https://api.zyphron.space/api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3003/api/v1/auth/google/callback

# ─── Email — Resend  (optional — 3,000 free emails/month) ───
# Get key at: resend.com → free plan → API Keys
RESEND_API_KEYS=
RESEND_FROM=Zyphron <noreply@zyphron.space>
RESEND_REPLY_TO=support@zyphron.space

# ─── AI — Groq  (optional — 6,000 free tokens/min) ──────────
# Get key at: console.groq.com → API Keys
GROQ_API_KEYS=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_FALLBACK_MODEL=llama3-8b-8192

# ─── Deployment ─────────────────────────────────────────────
BASE_DOMAIN=zyphron.space
USE_HTTPS=true
CONTAINER_REGISTRY=localhost:5000
DEPLOYMENT_MODE=docker        # docker (default) | k8s
DOCKER_NETWORK=zyphron_zyphron
PROJECTS_DIR=/tmp/zyphron/projects
MAX_CONCURRENT_BUILDS=5
BUILD_TIMEOUT=1800

# ─── Observability ──────────────────────────────────────────
PROMETHEUS_URL=http://localhost:9090

# ─── Frontend (local dev only) ──────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3003
NEXT_PUBLIC_APP_URL=http://localhost:3004
NEXT_PUBLIC_GRAFANA_URL=http://localhost:3002/grafana
NEXT_PUBLIC_GITHUB_CLIENT_ID=
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
